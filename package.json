{
  "packageManager": "bun@1.3.12",
  "type": "module",
  "workspaces": [
    "plugin",
    "backend"
  ],
  "scripts": {
    "check": "prettier --check . && oxlint && bun run --cwd plugin build && tsc -b && bun --cwd plugin check && bun --cwd backend check",
    "format": "prettier --write . && oxlint --fix",
    "dev": "bun run --parallel docs:dev backend:dev",
    "preview": "bun run --workspaces build && bun run --parallel backend:preview docs:dev",
    "backend:dev": "bun --cwd backend dev",
    "backend:preview": "bun --cwd backend preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docker:build": "docker build -t ghcr.io/tvcsantos/vitepress-knowledge-server .",
    "docker:run": "docker run --init -it --rm -p 3000:3000 ghcr.io/tvcsantos/vitepress-knowledge-server"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "oxlint": "^0.15.5",
    "prettier": "^3.4.2",
    "typescript": "^5.0.0"
  }
}
