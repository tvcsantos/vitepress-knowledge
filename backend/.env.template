# LiteLLM (https://docs.litellm.ai/docs/simple_proxy)
# Self-hosted OpenAI-compatible proxy supporting 100+ providers.
LITELLM_API_KEY=<replace-with-your-own>
LITELLM_BASE_URL=http://localhost:4000
# Comma-separated list of LiteLLM model aliases (as defined in your LiteLLM
# proxy config) as `alias[:Display Name]`.
LITELLM_MODELS=gpt-4o-mini:GPT 4o Mini

# Database
DATABASE_TYPE=sqlite
DATABASE_SQLITE_PATH=data/knowledge.db

# Server
PORT=5174
# Log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# Admin token for the site-management API (POST/PATCH/DELETE /api/sites and
# /api/sites/:id/knowledge). Leave empty to disable auth (not recommended).
# Generate: openssl rand -hex 32
ADMIN_TOKEN=

# Note: per-site config (app name, brand colors, docs URL, CORS origins, system
# prompt, welcome message, etc.) is managed via the sites API and stored in the
# database - not via environment variables.
