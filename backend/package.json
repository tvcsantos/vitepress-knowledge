{
  "name": "vitepress-knowledge-server",
  "version": "0.3.12",
  "description": "Self-hosted server for hosting the Chat UI for your VitePress website",
  "type": "module",
  "scripts": {
    "check": "vue-tsc --noEmit",
    "dev": "bun scripts/dev.ts",
    "build": "bun run build.ts",
    "preview": "bun run build.ts && bun run .output/server/index.js",
    "gen": "bun gen:sqlite",
    "gen:sqlite": "drizzle-kit generate --dialect sqlite --schema server/db/sqlite --out server/drizzle/sqlite --casing snake_case"
  },
  "dependencies": {
    "@egoist/tailwindcss-icons": "^1.9.2",
    "@hono/zod-validator": "^0.8.0",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@paralleldrive/cuid2": "^3.3.0",
    "@shikijs/langs": "^3.2.1",
    "@shikijs/themes": "^3.2.1",
    "@vueuse/core": "^14.2.1",
    "async-mutex": "^0.5.0",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "markdown-it": "^14.1.1",
    "pino": "^10.3.1",
    "shiki": "^3.2.1",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7"
  }
}
