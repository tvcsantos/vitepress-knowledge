{
  "name": "vitepress-knowledge-server",
  "version": "0.3.9",
  "description": "Self-hosted server for hosting the Chat UI for your VitePress website",
  "type": "module",
  "scripts": {
    "check": "check",
    "aframe": "bun ../node_modules/@aklinker1/aframe/bin/aframe.ts",
    "dev": "bun aframe",
    "build": "bun aframe build",
    "preview": "bun aframe build && bun .output/server-entry.ts",
    "gen": "bun gen:sqlite",
    "gen:sqlite": "drizzle-kit generate --dialect sqlite --schema server/db/sqlite --out server/drizzle/sqlite --casing snake_case"
  },
  "dependencies": {
    "@aklinker1/aframe": "^1.2.2",
    "@aklinker1/zero-ioc": "^1.5.1",
    "@aklinker1/zeta": "^2.2.0",
    "@egoist/tailwindcss-icons": "^1.9.2",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@paralleldrive/cuid2": "^3.3.0",
    "@shikijs/langs": "^3.2.1",
    "@shikijs/markdown-it": "^3.2.1",
    "@shikijs/themes": "^3.2.1",
    "@vueuse/core": "^14.2.1",
    "async-mutex": "^0.5.0",
    "consola": "^3.4.2",
    "croner": "^10.0.1",
    "dedent": "^1.7.2",
    "drizzle-orm": "^0.45.2",
    "markdown-it": "^14.1.1",
    "picocolors": "^1.1.1",
    "shiki": "^3.2.1",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aklinker1/check": "^2.4.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7"
  }
}
