{
  "name": "vitepress-knowledge-server",
  "version": "0.3.1",
  "description": "Self-hosted server for hosting the Chat UI for your VitePress website",
  "type": "module",
  "scripts": {
    "aframe": "bun ../node_modules/@aklinker1/aframe/bin/aframe.ts",
    "dev": "bun aframe",
    "build": "bun aframe build",
    "preview": "bun .output/server-entry.js",
    "gen": "bun gen:sqlite",
    "gen:sqlite": "drizzle-kit generate --dialect sqlite --schema server/db/sqlite --out server/drizzle/sqlite --casing snake_case",
    "docker:build": "bun run build && docker build -t vitepress-knowledge-server .",
    "docker:preview": "echo 'TODO'",
    "docker:push": "docker tag vitepress-knowledge-server aklinker1/vitepress-knowledge-server && docker push aklinker1/vitepress-knowledge-server"
  },
  "dependencies": {
    "@aklinker1/aframe": "^1.2.0",
    "@egoist/tailwindcss-icons": "^1.9.2",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/swagger": "^1.3.1",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@paralleldrive/cuid2": "^3.3.0",
    "@shikijs/langs": "^3.2.1",
    "@shikijs/markdown-it": "^3.2.1",
    "@shikijs/themes": "^3.2.1",
    "@vueuse/core": "^14.2.1",
    "async-mutex": "^0.5.0",
    "consola": "^3.4.2",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "markdown-it": "^14.1.1",
    "picocolors": "^1.1.1",
    "shiki": "^3.2.1",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@prerenderer/prerenderer": "^1.2.5",
    "@prerenderer/renderer-puppeteer": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "drizzle-kit": "^0.31.10",
    "puppeteer": "^24.42.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7"
  }
}
